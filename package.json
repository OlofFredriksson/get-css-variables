{
  "name": "get-css-variables",
  "version": "1.1.1",
  "description": "Import CSS variables into a JavaScript Object",
  "keywords": [
    "css"
  ],
  "homepage": "https://github.com/OlofFredriksson/get-css-variables#readme",
  "bugs": {
    "url": "https://github.com/OlofFredriksson/get-css-variables/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OlofFredriksson/get-css-variables.git"
  },
  "license": "MIT",
  "author": "Olof",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.mjs",
      "require": "./dist/cjs/index.cjs"
    }
  },
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.mjs",
  "types": "./dist/types/index.d.ts",
  "bin": "./bin/get-css-variables.js",
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "prebuild": "tsc",
    "build": "node build.mjs",
    "postbuild": "dts-bundle-generator -o dist/types/index.d.ts temp/types/index.d.ts",
    "eslint": "eslint .",
    "eslint:fix": "eslint . --fix",
    "lint": "run-s eslint prettier:check",
    "lint:fix": "run-s eslint:fix prettier:write",
    "prepack": "release-prepack --bundle",
    "postpack": "release-postpack",
    "prepublishOnly": "release-prepublish --bundle",
    "prettier:check": "prettier . --check",
    "prettier:write": "prettier . --write",
    "postpublish": "release-postpublish",
    "test": "node --test 'src/**/*.spec.js'",
    "postversion": "git push --follow-tags"
  },
  "commitlint": {
    "extends": "@forsakringskassan/commitlint-config/no-jira"
  },
  "prettier": "@forsakringskassan/prettier-config",
  "release": {
    "extends": "@forsakringskassan/semantic-release-config"
  },
  "dependencies": {
    "@adobe/css-tools": "^4.4.0"
  },
  "devDependencies": {
    "@forsakringskassan/commitlint-config": "3.6.7",
    "@forsakringskassan/eslint-config": "15.0.10",
    "@forsakringskassan/eslint-config-cli": "15.0.0",
    "@forsakringskassan/prettier-config": "3.7.0",
    "@html-validate/release-scripts": "7.2.4",
    "@tsconfig/node22": "22.0.5",
    "@types/node": "22.19.20",
    "dts-bundle-generator": "9.5.1",
    "esbuild": "0.28.0",
    "npm-pkg-lint": "5.1.5",
    "npm-run-all2": "9.0.1",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">= 22.0.0",
    "npm": ">= 11.0.0"
  }
}
